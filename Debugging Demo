public class DebugDemo
 {
    public static void main(String[] args) 
{

        int sum = 0;

        for (int i = 1; i <= 5; i++) 
{
            sum = sum + i;
        }

        if (sum > 10) {
            System.out.println("sum is greater than 10");
        } else
 {
            System.out.println("sum is 10 or less");
        }
    }
}